# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# FIREBASE_API_KEY: Web API Key of your Firebase project. Configure in the AI Studio Secrets panel.
FIREBASE_API_KEY=MY_FIREBASE_API_KEY

# FIREBASE_PROJECT_ID: The unique ID of your Firebase Project.
FIREBASE_PROJECT_ID=MY_FIREBASE_PROJECT_ID

# FIREBASE_APP_ID: The official App ID for your Firebase Android app.
FIREBASE_APP_ID=MY_FIREBASE_APP_ID
